# Postgres
POSTGRES_USER=prf
POSTGRES_PASSWORD=prf
POSTGRES_DB=prf_ai_pipeline
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# App runtime uses asyncpg; Alembic migrations use sync psycopg
DATABASE_URL=postgresql+asyncpg://prf:prf@localhost:5432/prf_ai_pipeline
DATABASE_URL_SYNC=postgresql+psycopg://prf:prf@localhost:5432/prf_ai_pipeline

# LangGraph checkpointer connects to the same instance, dedicated schema
CHECKPOINTER_DATABASE_URL=postgresql://prf:prf@localhost:5432/prf_ai_pipeline

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# LLM (provider-agnostic via LangChain init_chat_model)
LLM_PROVIDER=google_genai
LLM_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Only needed if LLM_PROVIDER=ollama and you're running the dockerized
# api/celery-worker (docker-compose.yml defaults this to
# http://host.docker.internal:11434 for you). Leave unset for a bare
# `uv run` against a local Ollama on the host — ChatOllama's own
# http://localhost:11434 default is already correct there.
OLLAMA_BASE_URL=

# LLM-as-judge model used by the evaluation framework. Kept different from
# LLM_MODEL on purpose — a model grading its own output is biased toward it.
JUDGE_PROVIDER=google_genai
JUDGE_MODEL=gemini-2.5-flash-lite

# Embeddings for campaign-knowledge RAG (provider-agnostic via init_embeddings).
# Anthropic has no embeddings API, so this defaults to OpenAI — set the key below.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Comma-separated allowlist for the API's CORS middleware. Defaults to the
# React dashboard's Vite dev server; add the deployed dashboard's origin here
# for anything beyond local dev.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# MCP servers
MCP_CRM_URL=http://localhost:8100/mcp
MCP_ADDRESS_URL=http://localhost:8101/mcp

# App
LOG_LEVEL=INFO
CONFIDENCE_THRESHOLD_DONOR_VERIFICATION=0.80
CONFIDENCE_THRESHOLD_ADDRESS_INTELLIGENCE=0.80
# Advisory only (non-blocking). Lower than the factual agents by design — a
# recommendation predicts a future gift rather than assessing a present fact.
CONFIDENCE_THRESHOLD_DONATION_RECOMMENDATION=0.50
MAJOR_GIFT_ASK_THRESHOLD=1000.0
